```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# Distribution files
dist/
build/
target/

# Python specific
*.pyo
*.pyd
*.so
*.egg-info/

# System files
.DS_Store
Thumbs.db
```